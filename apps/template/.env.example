# Sanity CMS Configuration
# Get these values from https://www.sanity.io/manage

# Your Sanity project ID (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id

# Dataset name - typically "production"
NEXT_PUBLIC_SANITY_DATASET=production

# API version - use a date format
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-10

# Optional: API token for write operations (if needed)
# SANITY_API_TOKEN=your_token_here
