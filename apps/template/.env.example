# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-10

# Optional: Sanity API Token (for write operations)
# SANITY_API_TOKEN=your_token_here

# Site URL (used for SEO / OpenGraph — update to your deployed domain)
NEXT_PUBLIC_SITE_URL=https://yourname.example.com

# PostHog Analytics (optional — omit to disable analytics entirely)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
